<Window x:Class="BulkCropAndResizeTool.FileFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Browse Source"
        Height="150" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Do you want to select a file or a folder?" 
                   FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="FileButton" Content="Image file" Width="80" Height="30" 
                    Margin="0,0,25,0" IsDefault="True" Click="FileButton_Click"/>
            <Button x:Name="FolderButton" Content="Folder" Width="80" Height="30" 
                    IsCancel="True" Click="FolderButton_Click"/>
        </StackPanel>
    </Grid>
</Window>