    <None Include=".github\upgrades\scenarios\dotnet-version-upgrade\upgrade-options.md" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Extended.Wpf.Toolkit" Version="5.1.2" />
  </ItemGroup>
</Project>