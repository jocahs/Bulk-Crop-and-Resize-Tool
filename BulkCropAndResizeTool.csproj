    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <UseWindowsDesktop>true</UseWindowsDesktop>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <None Include=".github\upgrades\scenarios\dotnet-version-upgrade\plan.md" />
