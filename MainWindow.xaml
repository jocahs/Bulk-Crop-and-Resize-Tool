<Window x:Class="ImageCropTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Crop Tool by João Silva"
        Width="1060" Height="720" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel (scrollable) -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" RenderTransformOrigin="1.012,0.375" Margin="0,0,0,0">
            <StackPanel Margin="10,5,10,5">
                <Label Content="Source folder or file:" FontWeight="Bold" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SrcBox" Grid.Column="0" Margin="0,0,5,0" Text="Write/paste path..." />
                    <Button Grid.Column="1" Content="Browse" Width="50" Height="25" Click="SrcBrowse_Click" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>
                    <Label Content="Output folder:" FontWeight="Bold" Margin="0,0,0,0" />
                    <DockPanel Grid.Column="1" LastChildFill="False">
                        <CheckBox x:Name="OpenAfterChk" IsChecked="True" DockPanel.Dock="Right" 
                            VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="Open folder when done" Width="130" TextAlignment="Right" Height="20"/>
                    </DockPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DstBox" Grid.Column="0" Margin="0,0,5,0" Text="Output folder..." />
                    <Button Grid.Column="1" Content="Browse" Width="50" Height="25" />
                </Grid>

                <Separator Margin="0,5,0,0" />

                <!-- Filename Group (simplified) -->
                <GroupBox Header="Output Filename" Margin="0,0,0,0">
                    <Grid x:Name="NameGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.RowSpan="3" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <CheckBox x:Name="NoOverwriteChk" IsChecked="True" 
                              HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,2">
                                <CheckBox.LayoutTransform>
                                    <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                                </CheckBox.LayoutTransform>
                            </CheckBox>

                            <TextBlock Text="Don't overwrite" TextWrapping="Wrap" TextAlignment="Center" Width="70" FontSize="13" FontWeight="Bold" />
                        </StackPanel>

                        <Border Grid.RowSpan="3" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1,0,0,0" Margin="0,4" Width="1" />

                        <RadioButton x:Name="ModePrefix" Grid.Row="0" Grid.Column="2" Margin="80,0,0,0" FontSize="16" Content="Prefix" Checked="ModePrefix_Checked" />
                        <RadioButton x:Name="ModeSuffix" Grid.Row="0" Grid.Column="3" IsChecked="True" Margin="18,0,0,0" FontSize="16" Content="Suffix" />

                        <Label x:Name="NameExample" Grid.Row="2" Grid.Column="2" Content="filename +" Height="35" FontSize="18" Margin="5,1,0,24" Width="160" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="NameBox" Grid.Column="3" Text="_cropped" HorizontalAlignment="Left" HorizontalContentAlignment="Left" FontSize="18" Margin="5,4,0,30" Grid.Row="2" Width="150" />
                        <TextBlock x:Name="PreviewLabel" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Text="filename.jpg" HorizontalAlignment="Center"  TextAlignment="Center" Foreground="Red" FontSize="18" FontWeight="Bold" Margin="0,35,0,0" Grid.RowSpan="2" Width="312" />
                    </Grid>
                </GroupBox>

                <Separator Margin="0,5,0,0" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0">
                        <GroupBox.Header>
                            <TextBlock Text="Action" FontWeight="Bold" FontSize="14" />
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ActionCrop" Content="Crop" IsChecked="True" Margin="5"/>
                            <RadioButton x:Name="ActionResize" Content="Resize" Margin="5"/>
                        </StackPanel>
                    </GroupBox>

                    <Border Grid.Column="1" 
                        Width="1" 
                        Margin="5,5,5,0" 
                        Background="#CCCCCC" 
                        VerticalAlignment="Stretch"/>

                    <GroupBox Grid.Column="2" HorizontalAlignment="Left" Margin="0,0,0,0">
                        <GroupBox.Header>
                            <TextBlock Text="Units" FontWeight="Bold" FontSize="14" />
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="UnitPixels" Content="Pixels" IsChecked="True" Margin="5"/>
                            <RadioButton x:Name="UnitMM" Content="Millimeters" Margin="5"/>
                            <RadioButton x:Name="UnitPer" Content="Percentage" Margin="5"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>

                <!-- Units -->

                <Separator Margin="0,5,0,0" />

                <!-- Dimensions -->

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Margin="0,0,0,0">
                        <GroupBox.Header>
                            <TextBlock Text="Dimensions"  FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        </GroupBox.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="20" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Source:" Margin="0,-2,0,0"  HorizontalContentAlignment="Center"/>
                            <TextBox x:Name="WidthSourceBox" Grid.Row="0" Grid.Column="1" Text="0 px" IsReadOnly="True" Background="LightGray" TextAlignment="Center" Margin="2,2,2,2" Height="20" VerticalAlignment="Center" />
                            <Label Grid.Row="0" Grid.Column="2" Content="×" Margin="0,5,0,2" FontSize="14" Padding="0"  HorizontalContentAlignment="Center"/>
                            <TextBox x:Name="HeightSourceBox" Grid.Row="0" Grid.Column="3" Text="0 px" IsReadOnly="True" Background="LightGray" TextAlignment="Center" Margin="2,2,2,2" Height="20"  VerticalAlignment="Center" />


                            <Label Grid.Row="1" Grid.Column="0" Content="Output:" Margin="0,-2,0,0" HorizontalContentAlignment="Center" />
                            <TextBox x:Name="WidthBox" Grid.Row="1" Grid.Column="1" Text="1024 px" TextAlignment="Center" Margin="2,2,2,2" Height="20" />
                            <Label Grid.Row="1" Grid.Column="2" Content="×" Margin="0,5,0,2" FontSize="14" Padding="0"  HorizontalContentAlignment="Center"/>
                            <TextBox x:Name="HeightBox" Grid.Row="1" Grid.Column="3" Text="768 px" TextAlignment="Center" Margin="2,2,2,2"  Height="20" />

                            <Label Grid.Row="2" Grid.Column="1" Content="↔" FontSize="40" Margin="0,-20,0,0" Padding="0" HorizontalContentAlignment="Center"/>
                            <Label Grid.Row="2" Grid.Column="3" Content="↕" FontSize="30" Margin="0,-10,0,-10" Padding="0" HorizontalContentAlignment="Center" FontWeight="Bold"/>

                        </Grid>
                    </GroupBox>

                    <Border Grid.Column="1" 
                        Width="1" 
                        Margin="5,5,5,0" 
                        Background="#CCCCCC" 
                        VerticalAlignment="Stretch"/>

                    <GroupBox Grid.Column="2" Margin="0,0,0,0">
                        <GroupBox.Header>
                            <TextBlock Text="Margins"  FontWeight="Bold" FontSize="14" Margin="0,0,0,0"/>
                        </GroupBox.Header>


                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="2" Grid.Column="0" Margin="0,0,0,0" Padding="0" HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="|⬅" FontSize="24">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="90" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                    <TextBlock Text=" Top" FontSize="16" VerticalAlignment="Center" Margin="-10,0,0,0"/>
                                </StackPanel>
                            </Label>
                            <Label Grid.Row="2" Grid.Column="2" Margin="0,-2,0,0" Padding="0" HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="|⬅" FontSize="24" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Left" FontSize="16" VerticalAlignment="Center"  Margin="-5,0,0,0"/>
                                </StackPanel>
                            </Label>

                            <TextBox Grid.Row="0" Grid.Column="0" Text="0 px" IsReadOnly="True" Background="LightGray" TextAlignment="Center" Margin="2,2,2,2" Height="20" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="2" Text="0 px" IsReadOnly="True" Background="LightGray" TextAlignment="Center" Margin="2,2,2,2" Height="20" VerticalAlignment="Center" />
                            <TextBox x:Name="MargintopBox" Grid.Row="1" Grid.Column="0" Text="0 px" TextAlignment="Center" Margin="2,2,2,2" Height="20" />
                            <TextBox x:Name="MarginLeftBox" Grid.Row="1" Grid.Column="2" Text="0 px" TextAlignment="Center" Margin="2,2,2,2"  Height="20" />
                        </Grid>
                    </GroupBox>
                </Grid>


                <Separator Margin="0,5,0,5" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Buttons -->
                        <RowDefinition Height="Auto"/>
                        <!-- ProgressBar -->
                        <RowDefinition Height="*"/>
                        <!-- LogTextBox - takes remaining space -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <Button x:Name="ResetBtn" Content="Reset" Width="80" Height="30" Margin="0,0,0,0" />
                        <Button x:Name="CancelBtn" Content="Cancel" Width="80" Height="30" IsEnabled="False" Margin="130,0,0,0"/>
                        <Button x:Name="CropBtn" Content="CROP IMAGES" Width="100" Height="30" Margin="10,0,0,0" Background="LightGreen" />
                    </StackPanel>

                    <ProgressBar x:Name="Progress" Grid.Row="1" Height="20" Margin="0,0,0,5" />

                    <TextBox x:Name="LogTextBox" Grid.Row="2" IsReadOnly="True" 
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                         Background="LightGray" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Right Panel (Preview) -->
        <Grid Grid.Column="1" Margin="10">
            <DockPanel>
                <!-- Toolbar at bottom -->
                <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="LightGray" BorderThickness="1"
                        CornerRadius="8" Padding="5" Margin="0,10,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="ZoomInBtn" Content="🔍 Zoom In" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Button x:Name="ZoomOutBtn" Content="🔍 Zoom Out" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Button x:Name="FitBtn" Content="⟳ Fit to Window" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Button x:Name="ActualSizeBtn" Content="1:1 Actual Size" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Separator Width="1" Height="20" Margin="5,0,5,0" Background="LightGray" />
                        <Button x:Name="PanModeBtn" Content="✋ Pan Mode" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Label x:Name="ZoomLabel" Content="Fit" Margin="10,0,5,0" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Preview Canvas -->
                <Border BorderBrush="DarkGray" BorderThickness="1" Background="LightGray" CornerRadius="5">
                    <Canvas x:Name="PreviewCanvas" Background="LightGray">
                        <ScrollViewer x:Name="ScrollViewer" 
                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Image x:Name="PreviewImage" Stretch="Uniform" />
                        </ScrollViewer>
                        <!-- Crop overlay (static position for now) -->
                        <Border x:Name="CropOverlay" 
                                BorderBrush="Red" BorderThickness="2" 
                                Background="#50FF0000" Visibility="Visible"
                                Width="200" Height="150" 
                                Canvas.Left="100" Canvas.Top="100" />
                    </Canvas>
                </Border>
            </DockPanel>
        </Grid>
    </Grid>
</Window>