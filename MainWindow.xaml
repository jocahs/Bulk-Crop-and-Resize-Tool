<Window x:Class="BulkCropAndResizeTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Crop and Resize Tool by João Silva"
        MinWidth="1085" MinHeight="745" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:BulkCropAndResizeTool" 
        xmlns:helpers="clr-namespace:BulkCropAndResizeTool.Helpers"
        xmlns:services="clr-namespace:BulkCropAndResizeTool.Services">


    <Window.Resources>
        <sys:String x:Key="UnitText">px</sys:String>
        <!-- Style for all RadioButtons when disabled -->
        <Style TargetType="RadioButton">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all GroupBoxes -->
        <Style TargetType="GroupBox">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                    <Setter Property="BorderBrush" Value="Gray" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="BorderBrush" Value="Blue" />
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all TextBoxes when disabled -->
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="LightGray" />
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all Labels when disabled -->
        <Style TargetType="Label">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all CheckBoxes when disabled -->
        <Style TargetType="CheckBox">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all TextBlocks when disabled -->
        <Style TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <StackPanel Margin="10,0,0,5">
            <Label Content="Source folder or file:" FontWeight="Bold" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SrcBox" 
                     Grid.Column="0" 
                     Margin="0,0,5,0" 
                     Text="{x:Static helpers:AppConstants.DefaultSrcBoxText}" 
                     Foreground="DarkOrange" 
                     TextAlignment="Left"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Left"
                     GotFocus="SrcBox_GotFocus"
                     LostFocus="SrcBox_LostFocus"
                     FontStyle="Italic" 
                     FontWeight="Bold" 
                     TextWrapping="Wrap" 
                     Height="35" 
                     BorderBrush="DarkOrange" 
                     BorderThickness="2"/>
                <Button x:Name="SrcBrowse" Grid.Column="1" Style="{StaticResource ActionButtonStyle}" Content="Browse"/>
            </Grid>           
            <Label Content="Output folder:" FontWeight="Bold" Margin="0,0,0,0" HorizontalAlignment="Left"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DstBox" 
                  Grid.Column="0" 
                  Margin="0,0,5,0" 
                  Text="{x:Static helpers:AppConstants.DefaultDstBoxText}" 
                  VerticalContentAlignment="Center" 
                  FontStyle="Italic" 
                  Foreground="MediumPurple" 
                  FontWeight="Bold" 
                  TextWrapping="Wrap" 
                  Height="35" 
                  GotFocus="DstBox_GotFocus"
                  LostFocus="DstBox_LostFocus"
                  BorderBrush="MediumPurple" 
                  BorderThickness="2"/>
                <Button Grid.Column="1"  x:Name="DstBrowse"  Style="{StaticResource ActionButtonStyle}" Content="Browse"/>
            </Grid>

            <DockPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5,0,-5">
                <CheckBox x:Name="OpenAfterChk" IsChecked="True" DockPanel.Dock="Right" Margin="5,0,10,0">
                    <CheckBox.LayoutTransform>
                        <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                    </CheckBox.LayoutTransform>
                </CheckBox>
                <TextBlock Text="Open folder when done" TextAlignment="Right" FontWeight="Bold" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Filename Group (simplified) -->
            <GroupBox Margin="0,0,0,0" Height="75">
                <GroupBox.Header>
                    <TextBlock Text="Output Filename" FontWeight="Bold" FontSize="14" />
                </GroupBox.Header>
                <Grid x:Name="NameGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65" />
                        <ColumnDefinition Width="2" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0">
                        <CheckBox x:Name="OverwriteChk" IsChecked="false" 
                              HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                        <TextBlock Text="Overwrite" TextWrapping="Wrap" TextAlignment="Center" FontWeight="Bold" />
                    </StackPanel>

                    <Border Grid.RowSpan="3" Grid.Column="1" BorderThickness="2" Margin="0,2,0,0" Width="2" VerticalAlignment="Stretch"/>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                        <RadioButton x:Name="ModePrefix" IsChecked="True" Margin="0,0,0,0" FontSize="16" Content="Prefix" VerticalContentAlignment="center"/>
                        <RadioButton x:Name="ModeSuffix" Margin="40,0,0,0" FontSize="16" Content="Suffix" VerticalContentAlignment="center"/>
                    </StackPanel>

                    <StackPanel x:Name="NameStackPanel" Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock x:Name="NameSource" Text="filename"  FontSize="16" Margin="2,0,0,0" HorizontalAlignment="Left" TextAlignment="Left" VerticalAlignment="Center" Foreground="Red" FontWeight="Bold" FontStyle="Italic"/>
                        <TextBox x:Name="PreSufBox" Text="_cropped" HorizontalAlignment="Right" TextAlignment="Right" VerticalAlignment="Bottom" FontSize="16" Margin="2,0,1,0" MaxWidth="100" MaxLength="10"  FontWeight="Bold" FontStyle="Italic" Foreground="MediumSeaGreen" />
                        <TextBlock x:Name="NameExtension" Text=".jpg"  FontSize="16" Margin="2,0,0,0" HorizontalAlignment="Left" TextAlignment="Left" VerticalAlignment="Center" Foreground="Red"  FontWeight="Bold" FontStyle="Italic" />

                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid  Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0">
                    <GroupBox.Header>
                        <TextBlock Text="Action" FontWeight="Bold" FontSize="14" />
                    </GroupBox.Header>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <RadioButton x:Name="ModeCrop" Content="Crop" IsChecked="True" Margin="10,5,5,5"/>
                        <RadioButton x:Name="ModeResize" Content="Resize"  Margin="10,5,5,5"/>
                    </StackPanel>
                </GroupBox>

                <!-- Units -->

                <GroupBox Grid.Column="2" Margin="0,0,0,0" >
                    <GroupBox.Header>
                        <TextBlock Text="Units" FontWeight="Bold" FontSize="14" />
                    </GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="UnitPixels" Content="Pixels" IsChecked="True" Margin="5" GroupName="UnitGroup" />
                        <RadioButton x:Name="UnitMM" Content="Millimeters" Margin="5" GroupName="UnitGroup" />
                        <RadioButton x:Name="UnitPer" Content="Percentage" Margin="5" GroupName="UnitGroup" />
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Dimensions -->

            <Grid  Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Margin="0,0,0,0">
                    <GroupBox.Header>
                        <TextBlock Text="Dimensions"  FontWeight="Bold" FontSize="14" Margin="0,0,0,0" />
                    </GroupBox.Header>
                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="25" />
                            <RowDefinition Height="25" />
                            <RowDefinition Height="25" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto" MinWidth="50"/>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="auto" MinWidth="50"/>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                       <Label Grid.Row="1" Grid.Column="1" Content="Source" Margin="0,0,0,0"  HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Padding="0"/>
                        <TextBox x:Name="WidthSourceBox" Text="0" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" Background="LightGray" TextAlignment="Right" Margin="0,0,0,0"  Height="20" MinWidth="40" Padding="0,0,0,0"/>
                        <Label Content="{DynamicResource UnitText}" Grid.Row="1" Grid.Column="3" Margin="0,0,0,0" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBox x:Name="HeightSourceBox" Text="0"  Grid.Row="1" Grid.Column="4" IsReadOnly="True" Background="LightGray" TextAlignment="Right" Margin="0,0,0,0"  Height="20" MinWidth="40" Padding="0" HorizontalAlignment="Center"/>
                        <Label Content="{DynamicResource UnitText}" Margin="0,0,0,0" Padding="0" Grid.Row="1" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <Label x:Name="OutputLabel" Grid.Row="2" Grid.Column="1" Content="Max Output" Margin="0,0,0,0" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Padding="0"/>
                        <xctk:IntegerUpDown Value="1024" x:Name="WidthBox" Grid.Row="2" Grid.Column="2" TextAlignment="Right" Margin="0,0,0,0" Height="20" MinWidth="40" MaxLength="5" Minimum="1" Maximum="99999" ClipValueToMinMax="False" Padding="0" HorizontalAlignment="Center" ShowButtonSpinner="False"/>
                       <Label Content="{DynamicResource UnitText}" Margin="0,0,0,0" Padding="0" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <xctk:IntegerUpDown Value="768" x:Name="HeightBox"  Grid.Row="2" Grid.Column="4" TextAlignment="Right" Margin="0,0,0,0"  Height="20" MinWidth="40" MaxLength="5" Minimum="1" Maximum="99999" ClipValueToMinMax="False" Padding="0" HorizontalAlignment="Center" ShowButtonSpinner="False"/>
                        <Label Content="{DynamicResource UnitText}" Margin="0,0,0,0" Padding="0" Grid.Row="2" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="↔" FontSize="40" Margin="0,-20,0,0" Padding="0" HorizontalContentAlignment="Center"/>
                        <Label Grid.Row="0" Grid.Column="4" Content="↕" FontSize="30" Margin="0,-12,0,0" Padding="0" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                    </Grid>
                </GroupBox>
                <GroupBox x:Name="AspectRatioGroup" Grid.Column="1" Margin="0,0,0,0">
                    <GroupBox.Header>
                        <TextBlock Text="Aspect Ratio"  FontWeight="Bold" FontSize="14" Margin="0,0,0,0"/>
                    </GroupBox.Header>
                    <StackPanel Orientation="Vertical" Grid.Row="0" Grid.RowSpan="3" Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0" Width="100">
                        <CheckBox x:Name="AspectRatio" IsChecked="False"  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                        <TextBlock Text="Keep aspect ratio" TextWrapping="Wrap" TextAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="MarginsSettings" Grid.Column="1" Margin="0,0,0,0">
                    <GroupBox.Header>
                        <TextBlock Text="Margins"  FontWeight="Bold" FontSize="14" Margin="0,0,0,0"/>
                    </GroupBox.Header>
                    <Grid   HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="25" />
                            <RowDefinition Height="25" />
                            <RowDefinition Height="25" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,0" HorizontalAlignment="Center">
                            <TextBlock Text="|⬅" FontSize="20" VerticalAlignment="Center" Margin="0,-5,0,0"/>
                            <TextBlock Text=" Left" FontSize="16" VerticalAlignment="Center"  Margin="-5,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,0,0" HorizontalAlignment="Center">
                            <TextBlock Text="|⬅" FontSize="20" Margin="0,0,0,-5">
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="90" />
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                            <TextBlock Text=" Top" FontSize="16" VerticalAlignment="Center" Margin="-5,0,0,0"/>
                        </StackPanel>

                        <TextBox Text="0" Grid.Row="1" Grid.Column="0" IsReadOnly="True" Background="LightGray" TextAlignment="Right" Margin="0,0,0,0"  Height="20" Width="40" Padding="0"   HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        <Label Content="{DynamicResource UnitText}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,0" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBox Text="0" Grid.Row="1" Grid.Column="2" IsReadOnly="True" Background="LightGray" TextAlignment="Right" Margin="0,0,0,0"  Height="20" Width="40" Padding="0,0,0,0"   HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        <Label Content="{DynamicResource UnitText}" Grid.Row="1" Grid.Column="3" Margin="0,0,0,0" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <xctk:IntegerUpDown Value="0" x:Name="MarginLeftBox" Grid.Row="2" Grid.Column="0" TextAlignment="Right" Margin="0,0,0,0"  Height="20" Width="40" MaxLength="5" Padding="0,0,0,0"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ShowButtonSpinner="False"/>
                        <Label Content="{DynamicResource UnitText}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,0" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <xctk:IntegerUpDown Value="0" x:Name="MargintopBox"  Grid.Row="2" Grid.Column="2" TextAlignment="Right" Margin="0,0,0,0"  Height="20" Width="40" MaxLength="5" Padding="0,0,0,0"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ShowButtonSpinner="False"/>
                        <Label Content="{DynamicResource UnitText}"  Grid.Row="2" Grid.Column="3" Margin="0,0,0,0" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    </Grid>
                </GroupBox>
            </Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                    <RowDefinition Height="Auto"/>
                    <!-- ProgressBar -->
                    <RowDefinition Height="*"/>
                    <!-- LogTextBox - takes remaining space -->
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,5,0,5">
                    <Button x:Name="ResetBtn" Content="Reset Settings" Style="{StaticResource ActionButtonStyle}" DockPanel.Dock="Left"/>
                    <Button x:Name="ResetAll" Content="Reset All" Style="{StaticResource ActionButtonStyle}" DockPanel.Dock="Left" Background="DarkOrange"/>
                    <Button x:Name="ActionBtn" Content="CROP IMAGE" Width="120" Style="{StaticResource ActionButtonStyle}"  IsEnabled="False" Background="LightSeaGreen" DockPanel.Dock="Right" FontWeight="Bold"/>
                    <Button x:Name="CancelBtn" Content="Cancel" Style="{StaticResource ActionButtonStyle}" IsEnabled="False" DockPanel.Dock="Right"  Width="100"  Background="red" HorizontalAlignment="Right"/>                    
                </DockPanel>
            </Grid>
            <ProgressBar x:Name="Progress" Height="20" Margin="0,0,0,5" />

                <TextBox x:Name="LogTextBox" IsReadOnly="True" 
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                         Background="LightGray" MaxHeight="250" Padding="2"/>
            
        </StackPanel>

        <!-- Right Panel (Preview) -->
        <Grid x:Name="RightPanelGrid" Grid.Column="1" Margin="10,0,0,0" >
            <Line X1="0" Y1="0" X2="0" Y2="1" Stroke="Gray" StrokeThickness="1" HorizontalAlignment="Left"  VerticalAlignment="Stretch" Stretch="Fill" Margin="-5,5,0,5"/>
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0">
                    <GroupBox x:Name="RotateGroupBox" Margin="0,0,0,5" BorderBrush="Green" Width="180" HorizontalAlignment="Left">
                        <GroupBox.Header>
                            <TextBlock Text="Rotate"  FontWeight="Bold" Foreground="Green" FontSize="14" Margin="0,0,0,0"/>
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button x:Name="RotateMore90" Content="↷ +90º"  Style="{StaticResource ToolbarButtonStyle}" Background="LightGreen" BorderBrush="Green" Cursor="Hand"/>
                            <Button x:Name="RotateMinus90" Content="↶ -90º" Style="{StaticResource ToolbarButtonStyle}" Background="LightGreen" BorderBrush="Green" Cursor="Hand"/>
                            <Button x:Name="Rotate180" Content="⟲ 180º" Style="{StaticResource ToolbarButtonStyle}" Background="LightGreen" BorderBrush="Green" Cursor="Hand"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox x:Name="ZoomGroupBox" Margin="0,0,0,5"  BorderBrush="DarkOrange">
                        <GroupBox.Header>
                            <TextBlock Text="Zoom" Foreground="OrangeRed" FontWeight="Bold" FontSize="14" Margin="0,0,0,0"/>
                        </GroupBox.Header>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Label x:Name="ZoomLabel" Content="Fit" Margin="0,0,0,0" FontSize="18" Foreground="DarkOrange" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalAlignment="Center" Width="60"/>
                            <Button x:Name="ZoomInBtn" Content="🔍➕" Style="{StaticResource ToolbarButtonStyle}" Cursor="Hand"/>
                            <Button x:Name="ZoomOutBtn" Content="🔍➖" Style="{StaticResource ToolbarButtonStyle}" Cursor="Hand"/>
                            <Button  x:Name="FitBtn" Content="⛶ Fit to Window" Style="{StaticResource ToolbarButtonStyle}" Cursor="Hand"/>
                            <Button x:Name="ActualSizeBtn" Content="Actual Size 1:1" Style="{StaticResource ToolbarButtonStyle}" Cursor="Hand"/>
                            <Button Grid.Column="5" x:Name="PanModeBtn" Content="✋ Pan" Style="{StaticResource ToolbarButtonStyle}" Cursor="Hand"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- Preview Canvas + Scrollbars -->
                <Border x:Name="PreviewBorder" Grid.Row="1" Grid.Column="0" BorderBrush="DarkGray" BorderThickness="1" Background="LightGray" CornerRadius="5"  ClipToBounds="True" Padding="0" MinWidth="610" MinHeight="610">
                    <Canvas x:Name="PreviewCanvas" Background="LightGray" MinWidth="600" MinHeight="600" Margin="4">
                        <Image x:Name="PreviewImage"  Stretch="Fill"/>
                        <Border x:Name="CropOverlay" BorderBrush="Red" BorderThickness="2" Background="#50FF0000" Visibility="Visible" Width="200" Height="150" Canvas.Left="30" Canvas.Top="20"/>
                    </Canvas>
                </Border>

                <ScrollBar x:Name="VScrollBar" Grid.Row="1" Grid.Column="1" Orientation="Vertical" Width="18" Margin="0,0,5,0" SmallChange="20" LargeChange="200"/>
                <ScrollBar x:Name="HScrollBar" Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Height="18" Margin="0,0,0,5" SmallChange="20" LargeChange="200"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
