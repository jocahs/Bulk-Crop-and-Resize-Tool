<Window x:Class="ImageCropTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Crop Tool by João Silva"
        Width="1060" Height="720" 
        WindowStartupLocation="CenterScreen"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit">


    <Window.Resources>
        <sys:String x:Key="UnitText">px</sys:String>
        <!-- Style for all RadioButtons when disabled -->
        <Style TargetType="RadioButton">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all GroupBoxes when disabled -->
        <Style TargetType="GroupBox">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all TextBoxes when disabled -->
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="LightGray" />
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all Labels when disabled -->
        <Style TargetType="Label">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all CheckBoxes when disabled -->
        <Style TargetType="CheckBox">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all TextBlocks when disabled -->
        <Style TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for all Buttons when disabled -->
        <Style TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="LightGray" />
                    <Setter Property="Foreground" Value="Gray" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="630" />
        </Grid.ColumnDefinitions>

        <!-- Left panel (scrollable) -->
        <StackPanel Margin="10,5,0,5">
            <Label Content="Source folder or file:" FontWeight="Bold" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SrcBox" Grid.Column="0" Margin="0,0,5,0" 
                     Text="Write/Paste/Browse the source path of a file or folder ------------->" 
                     TextAlignment="Left"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Left"
                     GotFocus="SrcBox_GotFocus"
                     LostFocus="SrcBox_LostFocus"
                     TextChanged="SrcBox_TextChanged" FontStyle="Italic"/>
                <Button Grid.Column="1" Content="Browse" Width="50" Height="25" Click="SrcBrowse_Click" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>
                <Label Content="Output folder:" FontWeight="Bold" Margin="0,0,0,0" />
                <DockPanel Grid.Column="1" LastChildFill="False">
                    <CheckBox x:Name="OpenAfterChk" IsChecked="True" DockPanel.Dock="Right" 
                            VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="Open folder when done" Width="130" TextAlignment="Right" Height="20"/>
                </DockPanel>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DstBox" Grid.Column="0" Margin="0,0,5,0" Text="Write/Paste/Browse output path if different from source folder --->" VerticalContentAlignment="Center" FontStyle="Italic"/>
                <Button Grid.Column="1" Content="Browse" Width="50" Height="25" Click="DstBrowse_Click" />
            </Grid>

            <Separator Margin="0,5,0,0" />

            <!-- Filename Group (simplified) -->
            <GroupBox Header="Output Filename" Margin="0,0,0,0">
                <Grid x:Name="NameGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0">
                        <CheckBox x:Name="NoOverwriteChk" IsChecked="True" 
                              HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
                            </CheckBox.LayoutTransform>
                        </CheckBox>

                        <TextBlock Text="Don't overwrite" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" FontWeight="Bold" />
                    </StackPanel>

                    <Border Grid.RowSpan="3" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1,0,0,0" Margin="0,2,0,2" Width="1" />

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                        <RadioButton x:Name="ModePrefix" IsChecked="True" Margin="0,0,0,0" FontSize="16" Content="Prefix" VerticalContentAlignment="center"/>
                        <RadioButton x:Name="ModeSuffix" Checked="ModeSuffix_Checked" Margin="40,0,0,0" FontSize="16" Content="Suffix" VerticalContentAlignment="center"/>
                    </StackPanel>

                    <StackPanel x:Name="NameStackPanel" Orientation="Horizontal" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock x:Name="NameExample" Text="filename"  FontSize="16" Margin="2,0,0,0" HorizontalAlignment="Left" TextAlignment="Left" VerticalAlignment="Center" Foreground="Red" FontWeight="Bold" FontStyle="Italic"/>
                        <TextBox x:Name="NameBox" Text="_cropped" HorizontalAlignment="Right" TextAlignment="Right" VerticalAlignment="Bottom" FontSize="16" Margin="2,0,1,0" MaxWidth="100" MaxLength="10"  FontWeight="Bold" FontStyle="Italic" Foreground="MediumSeaGreen" />
                        <TextBlock x:Name="NameExtension" Text=".jpg"  FontSize="16" Margin="2,0,0,0" HorizontalAlignment="Left" TextAlignment="Left" VerticalAlignment="Center" Foreground="Red"  FontWeight="Bold" FontStyle="Italic" />

                    </StackPanel>
                </Grid>
            </GroupBox>

            <Separator Margin="0,5,0,0" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0">
                    <GroupBox.Header>
                        <TextBlock Text="Action" FontWeight="Bold" FontSize="14" />
                    </GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ActionCrop" Content="Crop" IsChecked="True" Margin="5"/>
                        <RadioButton x:Name="ActionResize" Content="Resize" Margin="5"/>
                    </StackPanel>
                </GroupBox>

                <Border Grid.Column="1" 
                        Width="1" 
                        Margin="5,5,5,0" 
                        Background="#CCCCCC" 
                        VerticalAlignment="Stretch"/>

                <GroupBox Grid.Column="2" HorizontalAlignment="Left" Margin="0,0,0,0">
                    <GroupBox.Header>
                        <TextBlock Text="Units" FontWeight="Bold" FontSize="14" />
                    </GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="UnitPixels" Content="Pixels" IsChecked="True" Margin="5"/>
                        <RadioButton x:Name="UnitMM" Content="Millimeters" Margin="5"/>
                        <RadioButton x:Name="UnitPer" Content="Percentage" Margin="5"/>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Units -->

            <Separator Margin="0,5,0,0" />

            <!-- Dimensions -->

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Margin="0,0,5,0">
                    <GroupBox.Header>
                        <TextBlock Text="Dimensions"  FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    </GroupBox.Header>

                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="55" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="1" Grid.Column="0" Content="Source:" Margin="-5,0,0,0"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="WidthSourceBox" Text="0" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" Background="LightGray" TextAlignment="Right" Margin="0,0,0,0"  Height="20" Width="40" Padding="0,0,0,0"/>
                        <Label Content="{DynamicResource UnitText}" Margin="0,0,0,0" Padding="0" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                        <TextBox x:Name="HeightSourceBox" Text="0"  Grid.Row="1" Grid.Column="3" IsReadOnly="True" Background="LightGray" TextAlignment="Right" Margin="0,0,0,0"  Height="20" Width="40" Padding="0,0,0,0" HorizontalAlignment="Center"/>
                        <Label Content="{DynamicResource UnitText}" Margin="0,0,0,0" Padding="0" Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>


                        <Label Grid.Row="2" Grid.Column="0" Content="Output:" Margin="-5,0,0,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                        
                        <xctk:IntegerUpDown Value="1024" x:Name="WidthBox" Grid.Row="2" Grid.Column="1" TextAlignment="Right" Margin="0,0,0,0" Height="20" Width="40" MaxLength="5" Minimum="1" Maximum="99999" Padding="0,0,0,0" HorizontalAlignment="Center" ShowButtonSpinner="False"/>
                        <Label Content="{DynamicResource UnitText}" Margin="0,0,0,0" Padding="0" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>

                        <xctk:IntegerUpDown Value="768" x:Name="HeightBox"  Grid.Row="2" Grid.Column="3" TextAlignment="Right" Margin="0,0,0,0"  Height="20" Width="40" MaxLength="5" Padding="0,0,0,0" HorizontalAlignment="Center" ShowButtonSpinner="False"/>
                        <Label Content="{DynamicResource UnitText}" Margin="0,0,0,0" Padding="0" Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>

                        <Label Grid.Row="0" Grid.Column="1" Content="↔" FontSize="40" Margin="0,-20,0,-10" Padding="0" HorizontalContentAlignment="Center"/>
                        <Label Grid.Row="0" Grid.Column="3" Content="↕" FontSize="30" Margin="0,-15,0,-10" Padding="0" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                        <StackPanel x:Name="StackRatio" Orientation="Vertical" Grid.Row="0" Grid.RowSpan="3" Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0">
                            <CheckBox x:Name="AspectRatio" IsChecked="True"  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                                <CheckBox.LayoutTransform>
                                    <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
                                </CheckBox.LayoutTransform>
                            </CheckBox>
                            <TextBlock Text="Keep aspect ratio" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" FontWeight="Bold" Width="40"/>                            
                        </StackPanel>
                        
                    </Grid>
                </GroupBox>
                <GroupBox x:Name="MarginsSettings" Grid.Column="2" Margin="0,0,0,0" VerticalAlignment="Center">
                    <GroupBox.Header>
                        <TextBlock Text="Margins"  FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="70" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Margin="5,-2,10,0" HorizontalAlignment="Center">
                            <TextBlock Text="|⬅" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text=" Left" FontSize="16" VerticalAlignment="Center"  Margin="-5,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" Margin="10,0,10,0" HorizontalAlignment="Center">
                            <TextBlock Text="|⬅" FontSize="20" >
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="90" />
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                            <TextBlock Text=" Top" FontSize="16" VerticalAlignment="Center" Margin="-10,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                            <TextBox Text="0" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Background="LightGray" TextAlignment="Right" Margin="5,0,0,0"  Height="20" Width="40" Padding="0,0,0,0" HorizontalAlignment="Center"/>
                            <Label Content="{DynamicResource UnitText}" Margin="0,0,0,3" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                            <TextBox Text="0" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Background="LightGray" TextAlignment="Right" Margin="5,0,0,0"  Height="20" Width="40" Padding="0,0,0,0" HorizontalAlignment="Center"/>
                            <Label Content="{DynamicResource UnitText}" Margin="0,0,0,3" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                            <xctk:IntegerUpDown Value="0" x:Name="MarginLeftBox" Grid.Row="1" Grid.Column="1" TextAlignment="Right" Margin="5,0,0,0"  Height="20" Width="40" MaxLength="5" Padding="0,0,0,0" HorizontalAlignment="Center" ShowButtonSpinner="False"/>
                            <Label Content="{DynamicResource UnitText}" Margin="0,0,0,3" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                            <xctk:IntegerUpDown Value="0" x:Name="MargintopBox" Grid.Row="1" Grid.Column="1" TextAlignment="Right" Margin="5,0,0,0"  Height="20" Width="40" MaxLength="5" Padding="0,0,0,0" HorizontalAlignment="Center" ShowButtonSpinner="False"/>
                            <Label Content="{DynamicResource UnitText}" Margin="0,0,0,3" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>


            <Separator Margin="0,5,0,5" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                    <RowDefinition Height="Auto"/>
                    <!-- ProgressBar -->
                    <RowDefinition Height="*"/>
                    <!-- LogTextBox - takes remaining space -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button x:Name="ResetBtn" Content="Reset settings" Width="90" Height="30" Margin="0,0,0,0" />
                    <Button x:Name="CancelBtn" Content="Cancel" Width="80" Height="30" IsEnabled="False" Margin="130,0,0,0"/>
                    <Button x:Name="CropBtn" Content="CROP IMAGES" Width="100" Height="30" Margin="10,0,0,0" Background="LightGreen" />
                </StackPanel>

                <ProgressBar x:Name="Progress" Grid.Row="1" Height="20" Margin="0,0,0,5" />

                <TextBox x:Name="LogTextBox" Grid.Row="2" IsReadOnly="True" 
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                         Background="LightGray"/>
            </Grid>
        </StackPanel>

        <!-- Right Panel (Preview) -->
        <Grid Grid.Column="1" Margin="10">
            <DockPanel>
                <!-- Toolbar at bottom -->
                <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="LightGray" BorderThickness="1"
                        CornerRadius="8" Padding="5" Margin="0,10,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="ZoomInBtn" Content="🔍 Zoom In" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Button x:Name="ZoomOutBtn" Content="🔍 Zoom Out" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Button x:Name="FitBtn" Content="⟳ Fit to Window" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Button x:Name="ActualSizeBtn" Content="1:1 Actual Size" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Separator Width="1" Height="20" Margin="5,0,5,0" Background="LightGray" />
                        <Button x:Name="PanModeBtn" Content="✋ Pan Mode" Margin="2" Padding="8,5" Background="White" BorderBrush="LightGray" BorderThickness="1" Cursor="Hand" />
                        <Label x:Name="ZoomLabel" Content="Fit" Margin="10,0,5,0" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Preview Canvas -->
                <Border BorderBrush="DarkGray" BorderThickness="1" Background="LightGray" CornerRadius="5">
                    <Canvas x:Name="PreviewCanvas" Background="LightGray">
                        <Image x:Name="PreviewImage" Stretch="Uniform" />

                        <!-- Crop overlay (static position for now) -->
                        <Border x:Name="CropOverlay" 
                                BorderBrush="Red" BorderThickness="2" 
                                Background="#50FF0000" Visibility="Visible"
                                Width="200" Height="150" 
                                Canvas.Left="100" Canvas.Top="100" />
                    </Canvas>
                </Border>
            </DockPanel>
        </Grid>
    </Grid>
</Window>